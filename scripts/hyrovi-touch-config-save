#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path

import yaml

REPO_ROOT = Path("/opt/hyrovi-touch-panel/current")
if REPO_ROOT.exists():
    sys.path.insert(0, str(REPO_ROOT))

from app.config.storage import atomic_write_yaml  # noqa: E402


def main() -> int:
    if len(sys.argv) != 2:
        print("Usage: hyrovi-touch-config-save /path/to/config.yaml", file=sys.stderr)
        return 1

    target = Path(sys.argv[1])
    payload = sys.stdin.read()
    data = yaml.safe_load(payload) or {}
    if not isinstance(data, dict):
        print("Config payload must be a YAML mapping.", file=sys.stderr)
        return 1

    atomic_write_yaml(target, data, owner="root", group="hyrovi-panel", mode=0o640)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
